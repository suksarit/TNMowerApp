<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- 🔴 VOLT -->
    <TextView
        android:id="@+id/txtVolt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/default_voltage"
        android:textSize="28sp"



        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 🔴 TEMP LEFT -->
    <TextView
        android:id="@+id/txtTempL"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/default_temp_l"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/txtVolt"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/txtTempR"/>

    <!-- 🔴 TEMP RIGHT -->
    <TextView
        android:id="@+id/txtTempR"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/default_temp_r"
        android:textSize="18sp"
        android:gravity="end"
        app:layout_constraintTop_toBottomOf="@id/txtVolt"
        app:layout_constraintStart_toEndOf="@id/txtTempL"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 🔴 CURRENT -->
    <TextView
        android:id="@+id/txtM1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/default_m1"
        app:layout_constraintTop_toBottomOf="@id/txtTempL"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtM2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/default_m2"
        app:layout_constraintTop_toBottomOf="@id/txtM1"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtM3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/default_m3"
        app:layout_constraintTop_toBottomOf="@id/txtM2"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/txtM4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/default_m4"
        app:layout_constraintTop_toBottomOf="@id/txtM3"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- 🔴 STATUS -->
    <TextView
        android:id="@+id/txtStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/status_disconnected"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/txtM4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 🔴 BUTTON CONNECT -->
    <Button
        android:id="@+id/btnConnect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_connect"
        app:layout_constraintTop_toBottomOf="@id/txtStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDisconnect"
        android:layout_marginEnd="8dp"/>

    <!-- 🔴 BUTTON DISCONNECT -->
    <Button
        android:id="@+id/btnDisconnect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_disconnect"
        app:layout_constraintTop_toBottomOf="@id/txtStatus"
        app:layout_constraintStart_toEndOf="@id/btnConnect"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"/>

    <!-- 🔴 STOP -->
    <Button
        android:id="@+id/btnStop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_stop"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        app:layout_constraintTop_toBottomOf="@id/btnConnect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
